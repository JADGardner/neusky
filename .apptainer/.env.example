# .apptainer/.env — host-specific paths (not committed; copy to .env and edit)
# These paths are bind-mounted into the container at runtime.

# Directory containing datasets (NeRF-OSR, etc.)
DATA_PATH=/path/to/data

# Directory containing pretrained model checkpoints (RENI++, etc.)
MODEL_STORAGE_PATH=/path/to/model-storage

# Directory for training outputs
OUTPUTS_PATH=/path/to/outputs

# (Optional) Override where SIF + overlay are stored (defaults to .apptainer/)
# CONTAINER_DIR=/path/to/containers
